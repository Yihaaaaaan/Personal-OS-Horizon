{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80,
      "category": "tech-news"
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "TechCrunch AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "The Verge AI",
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Anthropic News",
        "url": "https://www.anthropic.com/rss.xml",
        "enabled": false,
        "category": "ai-labs"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "ai-labs"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "Product Hunt",
        "url": "https://www.producthunt.com/feed",
        "enabled": true,
        "category": "ai-products"
      },
      {
        "name": "arXiv AI",
        "url": "https://rss.arxiv.org/rss/cs.AI",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "arXiv Machine Learning",
        "url": "https://rss.arxiv.org/rss/cs.LG",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "Papers with Code",
        "url": "https://paperswithcode.com/latest",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "MarkTechPost",
        "url": "https://www.marktechpost.com/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "MIT Technology Review AI",
        "url": "https://www.technologyreview.com/topic/artificial-intelligence/feed",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Ahead of AI",
        "url": "https://magazine.sebastianraschka.com/feed",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "TechCrunch Startups",
        "url": "https://techcrunch.com/category/startups/feed/",
        "enabled": true,
        "category": "startups"
      },
      {
        "name": "Crunchbase News",
        "url": "https://news.crunchbase.com/feed/",
        "enabled": true,
        "category": "startups"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        }
      ],
      "users": [],
      "fetch_comments": 3
    },
    "github": [
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "claude-code",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true,
        "category": "ai-frameworks"
      },
      {
        "type": "repo_releases",
        "owner": "crewAIInc",
        "repo": "crewAI",
        "enabled": true,
        "category": "ai-frameworks"
      }
    ],
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["Python", "TypeScript"],
      "keywords": ["AI", "LLM", "agent"],
      "min_stars": 50,
      "max_items": 20,
      "category": "github-trending"
    },
    "google_news": {
      "enabled": true,
      "query": "AI startup funding OR AI company funding round OR AI venture capital OR AI product launch OR AI tool release OR AI conference 2026",
      "language": "en",
      "country": "US",
      "max_results": 20,
      "category": "ai-news"
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "ai_newz",
          "fetch_limit": 15,
          "category": "ai-news"
        }
      ]
    },
    "twitter": {
      "enabled": false
    },
    "openbb": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": null,
    "category_groups": {
      "AI News": {
        "categories": ["ai-news", "ai-labs"],
        "limit": 8
      },
      "AI Tools & Products": {
        "categories": ["ai-tools", "ai-products"],
        "limit": 5
      },
      "AI Research": {
        "categories": ["ai-research"],
        "limit": 5
      },
      "GitHub Trending": {
        "categories": ["github-trending", "ai-frameworks"],
        "limit": 5
      },
      "AI Events": {
        "categories": ["ai-events"],
        "limit": 5
      },
      "Startups & Funding": {
        "categories": ["startups"],
        "limit": 5
      },
      "Tech Community": {
        "categories": ["tech-news"],
        "limit": 5
      }
    },
    "default_group": "Other",
    "default_group_limit": 5
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "chat_id": "${TG_CHAT_ID}",
      "text": "#{summary?limit=3500&split=---}",
      "parse_mode": "Markdown"
    },
    "headers": ""
  }
}
